glob	C:\$Recycle.Bin\$I*

glob	C:\Users\*\NTUSER.DAT
glob	C:\Users\*\NTUSER.DAT.LOG1
glob	C:\Users\*\NTUSER.DAT.LOG2
glob	C:\Users\*\AppData\Local\Microsoft\Windows\UsrClass.dat
glob	C:\Users\*\AppData\Local\Microsoft\Windows\UsrClass.dat.LOG1
glob	C:\Users\*\AppData\Local\Microsoft\Windows\UsrClass.dat.LOG2
