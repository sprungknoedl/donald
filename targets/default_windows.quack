glob	C:\Users\*\AppData\Local\Microsoft\Edge\User Data\Default\History
glob	C:\Users\*\AppData\Roaming\Microsoft\Windows\PowerShell\PSReadline\ConsoleHost_history.txt
glob	C:\Users\*\AppData\Roaming\Microsoft\Windows\Recent\**
glob	C:\Users\*\AppData\Local\Microsoft\Windows\WebCache\**
